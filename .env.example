# Скопируй этот файл в .env.local и впиши значения.
#
# ── Облако Supabase (прод на Vercel) ──
# Дашборд → Project Settings → API
#   Project URL      → VITE_SUPABASE_URL
#   Project API keys → anon public → VITE_SUPABASE_ANON_KEY
# (VITE_SUPABASE_NO_PROXY не задавать — запросы идут через прокси /sb, обход ТСПУ.)
#
# ── Self-hosted Supabase (локалка / свой VPS) ──
#   VITE_SUPABASE_URL=http://localhost:8000   (или https://твой-домен)
#   VITE_SUPABASE_ANON_KEY=<ANON_KEY из docker/.env self-host>
#   VITE_SUPABASE_NO_PROXY=true               ← ходим напрямую, без прокси /sb
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
